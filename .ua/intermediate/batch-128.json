			"tags": ["websocket-client", "reconnection", "event-handler", "service"],
			"complexity": "complex",
			"languageNotes": "Models the WebSocket dependency behind a small structural `WebSocketLike` interface so browser, React Native, bun, and test-fake sockets all satisfy it without an adapter layer."
		},
