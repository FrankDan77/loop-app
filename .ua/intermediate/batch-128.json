			"summary": "Type-only re-export of the entire generated ACP SDK surface — the single sanctioned entry point both host-service and clients must import ACP types through, per Decision D7.",
			"tags": ["barrel", "type-definition", "protocol", "acp"],
			"complexity": "simple",
			"languageNotes": "Uses `export type *` so the re-export is erased at build time and carries zero runtime cost."
		},
		{
			"id": "file:packages/session-protocol/src/api.ts",
			"type": "file",
			"name": "api.ts",
			"filePath": "packages/session-protocol/src/api.ts",
			"summary": "Defines the client-facing ACP session API contract: zod input schemas for the session router, a pagination cursor codec for getMessages, and the structural `AcpSessionsApi` interface consumed by the React hooks.",
			"tags": [
				"validation",
				"type-definition",
				"api-contract",
				"serialization"
			],
			"complexity": "moderate",
			"languageNotes": "Uses `z.custom` to lightly re-validate ACP payload shapes without duplicating the sdk's own schema-checked types, since the sdk's zod schemas aren't part of its public export map."
		},
